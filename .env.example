DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=

POSTGRES_DB=calidad
POSTGRES_USER=calidad
POSTGRES_PASSWORD=calidad
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

APP_SLUG=calidad-platform
API_VERSION=v1
LANGUAGE_CODE=es-ar
TIME_ZONE=America/Argentina/Buenos_Aires
LOG_LEVEL=INFO
DJANGO_LOG_TO_FILE=False
LOG_DIR=runtime/logs
APP_LOG_FILE=calidad-platform.log
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGIN_REGEXES=

STORAGE_ROOT=storage
MEDIA_ROOT=storage/media
TEMP_FILES_ROOT=storage/tmp
STATIC_ROOT=runtime/staticfiles
FILE_UPLOAD_MAX_MEMORY_SIZE=5242880
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
LAST_ACTIVITY_UPDATE_WINDOW_SECONDS=300
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_MINUTES=480
DRF_ANON_RATE=60/minute
DRF_USER_RATE=600/hour
DRF_LOGIN_RATE=10/minute
