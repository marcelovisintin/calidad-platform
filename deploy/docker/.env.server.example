APP_SLUG=calidad-platform
PUBLIC_HOSTNAME=calidad.local
FRONTEND_BIND_PORT=8088
FRONTEND_TLS_BIND_PORT=8443
TLS_CERT_DAYS=825
TLS_SAN=DNS:localhost,DNS:calidad.local,DNS:calidad-srv,IP:127.0.0.1

DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=calidad.local,calidad-srv,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://calidad.local,http://calidad-srv,http://localhost,http://127.0.0.1,https://localhost:8443,https://calidad.local:8443
DJANGO_DEBUG=False

POSTGRES_DB=calidad
POSTGRES_USER=calidad
POSTGRES_PASSWORD=change-me-now
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

LANGUAGE_CODE=es-ar
TIME_ZONE=America/Argentina/Buenos_Aires
LOG_LEVEL=INFO
DJANGO_LOG_TO_FILE=true
APP_LOG_FILE=calidad-platform.log

CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_ORIGIN_REGEXES=

HOST_POSTGRES_DATA=D:/calidad-platform/postgres
HOST_MEDIA_ROOT=D:/calidad-platform/storage/media
HOST_TMP_ROOT=D:/calidad-platform/storage/tmp
HOST_STATIC_ROOT=D:/calidad-platform/runtime/staticfiles
HOST_LOG_ROOT=D:/calidad-platform/runtime/logs
HOST_BACKUP_ROOT=D:/calidad-platform/backups
HOST_TLS_CERTS=D:/calidad-platform/runtime/certs

STORAGE_ROOT=/srv/calidad/storage
MEDIA_ROOT=/srv/calidad/storage/media
TEMP_FILES_ROOT=/srv/calidad/storage/tmp
STATIC_ROOT=/srv/calidad/runtime/staticfiles
LOG_DIR=/srv/calidad/runtime/logs

FILE_UPLOAD_MAX_MEMORY_SIZE=5242880
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
LAST_ACTIVITY_UPDATE_WINDOW_SECONDS=300
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_MINUTES=480
DRF_ANON_RATE=60/minute
DRF_USER_RATE=600/hour
DRF_LOGIN_RATE=10/minute

GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
BACKUP_RETENTION_DAYS=14
